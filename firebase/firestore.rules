rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if request is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Documents collection rules
    match /documents/{docId} {
      allow read, delete: if isAuthenticated() && resource.data.sessionId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.sessionId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.sessionId == request.auth.uid && request.resource.data.sessionId == request.auth.uid;
    }

    // Chunks collection rules
    match /chunks/{chunkId} {
      allow read, delete: if isAuthenticated() && resource.data.sessionId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.sessionId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.sessionId == request.auth.uid && request.resource.data.sessionId == request.auth.uid;
    }

    // StudyKits collection rules (keyed by the user's UID)
    match /studyKits/{kitId} {
      allow read, write: if isAuthenticated() && kitId == request.auth.uid;
    }
  }
}
